# Supabase project credentials — template for all environment files.
# .env.dev, .env.staging, and .env.prod are tracked Flutter assets (pubspec.yaml)
# bundled into the app at build time via flutter_dotenv. They contain non-secret
# defaults and placeholders — real secrets (hosted keys, FCM creds) must be
# filled in locally and never committed with actual values.
# The Flutter app always reads SUPABASE_URL / SUPABASE_ANON_KEY.
# In .env.dev, set those two values to the local supabase start output.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key-from-dashboard>
MAPBOX_ACCESS_TOKEN=<mapbox-public-token>
GOOGLE_WEB_CLIENT_ID=<google-oauth-web-client-id>
GOOGLE_IOS_CLIENT_ID=<google-oauth-ios-client-id>
APPLE_SERVICE_ID=com.gridl.uff
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-dashboard>
SUPABASE_DB_PASSWORD=<database-password>

# Push notification secrets (send-notification Edge Function)
# For hosted environments these values are also required in `supabase secrets`.
FCM_PROJECT_ID=<fcm-project-id-from-firebase-console>
FCM_CLIENT_EMAIL=<fcm-service-account-email>
FCM_PRIVATE_KEY=<fcm-private-key-pem-from-service-account-json>
NOTIFICATION_WEBHOOK_SECRET=<random-secret-for-webhook-auth>

# Local development (supabase start defaults; in .env.dev mirror URL/anon into
# SUPABASE_URL and SUPABASE_ANON_KEY so the app points at the local stack)
SUPABASE_LOCAL_URL=http://127.0.0.1:54321
SUPABASE_LOCAL_ANON_KEY=<printed-by-supabase-start>
SUPABASE_LOCAL_SERVICE_ROLE_KEY=<printed-by-supabase-start>
